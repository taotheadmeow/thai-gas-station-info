# Frontend API base URL
# Example:
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787

# Public permissions endpoint
# If omitted, frontend will use: /api/permissions/public
VITE_PUBLIC_PERMISSIONS_PATH=/api/permissions/public

# Stations endpoint
# If omitted, frontend will use: /api/stations
VITE_STATIONS_PATH=/api/stations

# Cloudflare Turnstile site key for create station form
# Leave empty to disable captcha on frontend
VITE_TURNSTILE_SITE_KEY=

# Default map center (Bangkok example)
VITE_DEFAULT_LAT=13.7563
VITE_DEFAULT_LNG=100.5018

# Initial map zoom
VITE_DEFAULT_ZOOM=12

# Optional request radius fallback in kilometers
VITE_DEFAULT_RADIUS_KM=30